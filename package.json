{
  "name": "artha",
  "version": "0.1.0",
  "description": "Certified product-meaning for AI coding agents — mine, certify, and serve a team's decisions/conventions/invariants over MCP.",
  "type": "module",
  "license": "MIT",
  "author": "Brijesh Chandrakar",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "artha": "dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup && npm run build:web",
    "build:web": "vite build --config web/vite.config.ts",
    "dev": "tsup --watch",
    "dev:web": "vite --config web/vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "typecheck:web": "tsc -p web/tsconfig.json"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "commander": "^12.1.0",
    "ink": "^5.2.1",
    "react": "^18.3.1",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.20.8",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "ink-testing-library": "^4.0.0",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite": "^5.4.21",
    "vitest": "^2.1.8"
  }
}
